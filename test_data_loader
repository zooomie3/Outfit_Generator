from data_loader import load_weather, load_clothing, get_temperature_for_date

def run_tests():
    # Test if files loaded correctly and have expected structure
    weather_df = load_weather("Fashionista/weather.csv")
    clothing_df = load_clothing("Fashionista/closet.csv")

    print("\n✅ Loaded weather rows/cols:", weather_df.shape)
    print("✅ Loaded clothing rows/cols:", clothing_df.shape)

    # Check that required columns exist and that _standardize_columns worked (lowercase, no spaces)
    assert "date" in weather_df.columns, "weather_df missing 'date'"
    assert "temp_celsius" in weather_df.columns, "weather_df missing 'temp_celsius'"

    assert "item_id" in clothing_df.columns, "clothing_df missing 'item_id'"
    assert "position" in clothing_df.columns, "clothing_df missing 'position'"
    assert "type" in clothing_df.columns, "clothing_df missing 'type'"

    print("\n✅ Required columns exist.")

    # Prints a preview to ensure data looks correct after loading and cleaning
    print("\n--- Weather preview ---")
    print(weather_df[["date", "temp_celsius"]].head())

    print("\n--- Clothing preview ---")
    print(clothing_df.head())

    # Tests that temperature lookup works for a known date
    example_date = str(weather_df["date"].iloc[0])  # first date in file
    category = get_temperature_for_date(example_date, weather_df)
    print(f"\n✅ Category for {example_date}: {category}")
    assert category in {"COLD", "MILD", "WARM", "HOT"}, "Returned invalid category"

    # Test temperature lookup on a date that doesn't exist
    missing_date = "1900-01-01"
    category2 = get_temperature_for_date(missing_date, weather_df)
    print(f"✅ Category for missing date {missing_date}: {category2}")
    assert category2 in {"COLD", "MILD", "WARM", "HOT"}

    print("\nALL TESTS PASSED.")

if __name__ == "__main__":
    run_tests()

